---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Yarışmalar" description="Taragay Roket Takımı Yarışmaları">
  <section class="flex justify-center items-center bg-black min-h-screen text-white font-nasa px-6">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-center mb-12">
        Yarışma Geçmişimiz
      </h1>

      <div class="relative border-l-2 border-emerald-400 pl-20 space-y-12">
        <div class="relative">
          <div class="absolute -left-12 top-1 w-5 h-5 rounded-full bg-emerald-400"></div>
          <h2 class="text-2xl font-semibold mb-2">2025 – Dikey İnişli Roket Yarışması</h2>
          <p class="text-gray-300 text-sm leading-relaxed">
            2025 yılında geliştirilen ikinci nesil dikey iniş roketimiz ile Teknofest yarışmasına katılım sağlandı.  
            Gelişmiş kontrol algoritmaları ve yeni itki sistemiyle başarılı test uçuşları gerçekleştirildi.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
